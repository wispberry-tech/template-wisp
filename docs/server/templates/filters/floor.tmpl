{% extends "layouts/doc-layout" %}

{% block title %}Floor Filter - Wisp Template Documentation{% end %}

{% block body %}
<h1>Floor Filter</h1>

<p>Rounds a number down to the nearest integer.</p>

<h2>Syntax</h2>
<pre><code>{% raw %}
{{ number | floor }}
{% endraw %}</code></pre>

<h2>Examples</h2>
<pre><code>{% raw %}
{{ 4.9 | floor }}
{% endraw %}</code></pre>
<p><strong>Output:</strong> 4</p>

<pre><code>{% raw %}
{{ -4.1 | floor }}
{% endraw %}</code></pre>
<p><strong>Output:</strong> -5</p>

<pre><code>{% raw %}
{{ 5.0 | floor }}
{% endraw %}</code></pre>
<p><strong>Output:</strong> 5</p>

<h2>Notes</h2>
<p>For negative numbers, floor moves away from zero (e.g. -4.1 becomes -5). For exact integers, the value is returned unchanged.</p>

<h2>See Also</h2>
<ul>
  <li><a href="/docs/filters/ceil">ceil</a></li>
  <li><a href="/docs/filters/round">round</a></li>
  <li><a href="/docs/filters/abs">abs</a></li>
</ul>
{% end %}
