{% extends "layouts/doc-layout" %}

{% block title %}Round Filter - Wisp Template Documentation{% end %}

{% block body %}
<h1>Round Filter</h1>

<p>Rounds a number to a specified number of decimal places.</p>

<h2>Syntax</h2>
<pre><code>{% raw %}
{{ number | round }}
{{ number | round: precision }}
{% endraw %}</code></pre>

<h2>Examples</h2>
<pre><code>{% raw %}
{{ 3.14159 | round: 2 }}
{% endraw %}</code></pre>
<p><strong>Output:</strong> 3.14</p>

<pre><code>{% raw %}
{{ 4.5 | round }}
{% endraw %}</code></pre>
<p><strong>Output:</strong> 5</p>

<pre><code>{% raw %}
{{ 3.14159 | round: 4 }}
{% endraw %}</code></pre>
<p><strong>Output:</strong> 3.1416</p>

<h2>Notes</h2>
<p>When no precision is given, the number is rounded to the nearest integer (0 decimal places). Uses standard half-up rounding.</p>

<h2>See Also</h2>
<ul>
  <li><a href="/docs/filters/ceil">ceil</a></li>
  <li><a href="/docs/filters/floor">floor</a></li>
</ul>
{% end %}
