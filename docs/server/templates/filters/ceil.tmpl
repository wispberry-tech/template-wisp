{% extends "layouts/doc-layout" %}

{% block title %}Ceil Filter - Wisp Template Documentation{% end %}

{% block body %}
<h1>Ceil Filter</h1>

<p>Rounds a number up to the nearest integer.</p>

<h2>Syntax</h2>
<pre><code>{% raw %}
{{ number | ceil }}
{% endraw %}</code></pre>

<h2>Examples</h2>
<pre><code>{% raw %}
{{ 4.1 | ceil }}
{% endraw %}</code></pre>
<p><strong>Output:</strong> 5</p>

<pre><code>{% raw %}
{{ -4.9 | ceil }}
{% endraw %}</code></pre>
<p><strong>Output:</strong> -4</p>

<pre><code>{% raw %}
{{ 5.0 | ceil }}
{% endraw %}</code></pre>
<p><strong>Output:</strong> 5</p>

<h2>Notes</h2>
<p>For negative numbers, ceiling moves toward zero (e.g. -4.9 becomes -4). For exact integers, the value is returned unchanged.</p>

<h2>See Also</h2>
<ul>
  <li><a href="/docs/filters/floor">floor</a></li>
  <li><a href="/docs/filters/round">round</a></li>
  <li><a href="/docs/filters/abs">abs</a></li>
</ul>
{% end %}
