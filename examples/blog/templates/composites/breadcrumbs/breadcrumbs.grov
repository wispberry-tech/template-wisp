<Component name="Breadcrumbs">
<nav class="breadcrumb">
  <For each={breadcrumbs} as="crumb">
    <If test={crumb.href}>
      <a href="{% crumb.href %}">{% crumb.label %}</a>
      <span class="breadcrumb-sep">/</span>
    <Else>
      <span class="breadcrumb-current">{% crumb.label %}</span>
    </If>
  </For>
</nav>
</Component>
