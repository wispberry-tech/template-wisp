<Component name="AuthorCard" name slug bio="" avatar_url="" role="">
<div class="author-card">
  <If test={avatar_url}>
    <div class="author-avatar">
      <img src="{% avatar_url %}" alt="{% name %}">
    </div>
  </If>
  <div class="author-info">
    <h3><a href="/author/{% slug %}">{% name %}</a></h3>
    <If test={role}><span class="author-role">{% role %}</span></If>
    <If test={bio}><p class="author-bio">{% bio %}</p></If>
    <Slot />
  </div>
</div>
</Component>
