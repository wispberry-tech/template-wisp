{% extends "docs-layout.grov" %}

{% block title %}{{ page.title }} &mdash; {{ site_name }}{% endblock %}

{% block content %}
{% meta name="description" content="Grove template engine documentation" %}

<article class="doc-page">
  <h1>{{ page.title }}</h1>
  <div class="doc-body">
    {{ page.body | safe }}
  </div>
</article>

{% render "partials/prev-next.grov" prev=prev next=next %}
{% endblock %}
