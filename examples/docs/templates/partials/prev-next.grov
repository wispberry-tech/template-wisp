<Component name="PrevNext" prev next>
<nav class="prev-next">
  <If test={prev}>
    <a href="/docs/{% prev.section_slug %}/{% prev.slug %}" class="prev-next-link prev-link">
      &larr; {% prev.title %}
    </a>
  <Else />
    <span></span>
  </If>
  <If test={next}>
    <a href="/docs/{% next.section_slug %}/{% next.slug %}" class="prev-next-link next-link">
      {% next.title %} &rarr;
    </a>
  <Else />
    <span></span>
  </If>
</nav>
</Component>
